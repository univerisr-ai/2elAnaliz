# Telegram bot tokens (one or both)
TELEGRAM_BOT_TOKEN_1=
TELEGRAM_BOT_TOKEN_2=

# Allowed user/chat ids for security
TELEGRAM_ALLOWED_CHAT_IDS=-5083436032

# Optional: force all replies to this chat id (recommended for group-only output)
TELEGRAM_FORCE_CHAT_ID=-5083436032

# Optional: bot-only relay mode (repository_dispatch payload alanlari)
TELEGRAM_SOURCE_FILE_ID=
TELEGRAM_SOURCE_FILE_NAME=
TELEGRAM_SOURCE_CHAT_ID=
TELEGRAM_SOURCE_TOKEN_HINT=

# Polling configuration
TELEGRAM_POLL_LIMIT=50

# Analyzer knobs
MIN_DISCOUNT_RATIO=0.10
MAX_RESULTS=40
ANALYZE_LATEST_WHEN_NO_NEW=false
AI_PROVIDER=none
OPENROUTER_API_KEY=
OPENROUTER_MODELS=qwen/qwen3-coder:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free
MAX_AI_FALLBACK_MODELS=3
MAX_AI_MODEL_LOOKUPS=8
MAX_WEB_MODEL_LOOKUPS=14

# Optional: local file analyze mode
INPUT_FILE=

# Optional: local dashboard metadata
DEPLOY_TARGET=vercel
VERCEL_PROJECT_NAME=
SCRAPER_SOURCE_REPOSITORY=univerisr-ai/yenitest
SCRAPER_RUN_URL=
SCRAPER_GITHUB_RUN_ID=
SCRAPER_ARTIFACT_NAME=
SCRAPER_STATUS=SCRAPE_COMPLETED
SCRAPER_LISTING_COUNT=0
SCRAPER_STARTED_AT=
SCRAPER_FINISHED_AT=
SCRAPER_PIPELINE_MESSAGE=
SCRAPER_IS_FALLBACK=false
