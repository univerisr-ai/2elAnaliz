ANALYZE_LATEST_WHEN_NO_NEW=false
AI_PROVIDER=none
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
MAX_WEB_MODEL_LOOKUPS=14

# Optional: local file analyze mode
INPUT_FILE=
